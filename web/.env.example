# Copy to .env for local development and fill in from Supabase:
# Project Settings -> API.
#
# For GitHub Pages, add these with the same names under repository
# Settings -> Secrets and variables -> Actions -> Repository secrets.
# The anon key is safe to ship to the browser: migration 0006 makes the API
# strictly read-only (RLS with SELECT-only policies).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
